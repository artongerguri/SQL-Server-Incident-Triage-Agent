# Optional. ADK runs only after explicit approval in the UI.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local SQLite memory stores only redacted incident data.
INCIDENT_MEMORY_PATH=data/incidents.db

# Live MCP diagnostics are disabled by default. Use a dedicated read-only login.
SQLSERVER_MCP_ENABLE_LIVE=false
SQLSERVER_CONNECTION_STRING=
SQLSERVER_QUERY_TIMEOUT_SECONDS=10
